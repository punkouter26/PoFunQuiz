    .mp-game-row .material-icons { color: var(--primary-color, #6366f1); font-size: 1.2rem; }

    .mp-game-host { flex: 1; font-weight: 700; font-size: var(--text-sm); color: var(--text-primary); }
    .mp-game-id   { font-size: var(--text-xs); color: var(--text-secondary); font-family: monospace; }
    .mp-game-join-icon { color: var(--text-secondary) !important; }

    .mp-games-loading {
        display: flex;
        align-items: center;
        gap: 0.5rem;
