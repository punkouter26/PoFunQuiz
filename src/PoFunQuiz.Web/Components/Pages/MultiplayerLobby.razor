@page "/multiplayer"
@using PoFunQuiz.Web.Features.Multiplayer
@using PoFunQuiz.Web.Models
@inject GameClientService GameService
@inject NavigationManager Navigation
@inject GameState GameState
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Multiplayer - PoFunQuiz</PageTitle>

<SectionContent SectionName="HeaderContent">
    <div class="d-flex align-items-center">
        <span class="material-icons me-2" style="font-size: 1.2rem;">people</span>
        <span class="app-title">Multiplayer</span>
    </div>
</SectionContent>

<div class="mp-container">
    @if (currentState == null)
    {
        <!-- Hero banner -->
        <div class="mp-hero">
            <div class="mp-hero-bg"></div>
            <h2 class="mp-hero-title">Multiplayer Arena</h2>
            <p class="mp-hero-sub">Challenge a friend in real-time!</p>
        </div>

        <!-- Name field (shared between both tabs) -->
        <RadzenCard class="mp-form-card">
            <RadzenStack Gap="1rem">
                <div class="mp-field">
                    <label>Your Name</label>
                    <RadzenTextBox @bind-Value="playerName" Placeholder="Enter your name" Style="width:100%;" />
                </div>

                <!-- Action buttons -->
                <div class="mp-action-row">
                    <button class="mp-action-btn mp-btn-primary @(string.IsNullOrWhiteSpace(playerName) ? "mp-btn-disabled" : "")"
                            @onclick="CreateGame" disabled="@string.IsNullOrWhiteSpace(playerName)">
                        <span class="material-icons">add_circle</span>
                        Create Game
                    </button>
                    <button class="mp-action-btn mp-btn-secondary @(string.IsNullOrWhiteSpace(playerName) ? "mp-btn-disabled" : "")"
                            @onclick='@(async () => { activeTab = (activeTab == "join" ? "create" : "join"); if (activeTab == "join") await RefreshOpenGames(); })'
                            disabled="@string.IsNullOrWhiteSpace(playerName)">
                        <span class="material-icons">login</span>
                        Join Game
                    </button>
                </div>

                @if (activeTab == "join")
                {
                    <div class="mp-join-panel">
                        @if (isLoadingGames)
                        {
                            <div class="mp-games-loading">
                                <span class="material-icons rotating">sync</span>
                                Looking for open games…
                            </div>
                        }
                        else if (openGames.Count == 0)
                        {
                            <div class="mp-no-games">
                                <span class="material-icons">wifi_off</span>
                                <span>No open games right now. Ask a friend to create one!</span>
                            </div>
                        }
                        else
                        {
                            <p class="mp-join-hint">Select a game to join:</p>
                            @foreach (var game in openGames)
                            {
                                <button class="mp-game-row @(string.IsNullOrWhiteSpace(playerName) ? "mp-btn-disabled" : "")"
                                        @onclick="@(async () => await JoinOpenGame(game.GameId))"
                                        disabled="@string.IsNullOrWhiteSpace(playerName)">
                                    <span class="material-icons">person</span>
                                    <span class="mp-game-host">@game.HostName</span>
                                    <span class="mp-game-id">@game.GameId</span>
                                    <span class="material-icons mp-game-join-icon">chevron_right</span>
                                </button>
                            }
                        }
                        <button class="mp-refresh-btn" @onclick="RefreshOpenGames">
                            <span class="material-icons">refresh</span> Refresh
                        </button>
                    </div>
                }

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="mp-error-banner">
                        <span class="material-icons" style="font-size:1.1rem;">error_outline</span>
                        @errorMessage
                    </div>
                }
            </RadzenStack>
        </RadzenCard>
    }
    else
    {
        <!-- Game ID banner -->
        <div class="mp-id-banner">
            <span class="material-icons">share</span>
            <div>
                <p class="mp-id-label">Game ID</p>
                <p class="mp-id-value">@currentState.GameId</p>
            </div>
        </div>

        <!-- Versus layout -->
        <div class="mp-versus">
            <RadzenCard class="mp-player-card mp-player-primary">
                <div class="mp-avatar">@SafeInitials(currentState.Player1Name)</div>
                <h3>@currentState.Player1Name</h3>
                <p class="mp-score">@currentState.Player1Score</p>
            </RadzenCard>

            <div class="mp-vs">VS</div>

            <RadzenCard class="mp-player-card mp-player-secondary">
                <div class="mp-avatar">@(currentState.Player2Name == "Waiting..." ? "?" : SafeInitials(currentState.Player2Name))</div>
                <h3>@currentState.Player2Name</h3>
                <p class="mp-score">@currentState.Player2Score</p>
            </RadzenCard>
        </div>

        <!-- Action area -->
        <div class="mp-actions">
            @if (!currentState.IsGameStarted)
            {
                @if (isHost && currentState.Player2Name != "Waiting...")
                {
                    @if (isStartingGame)
                    {
                        <div class="mp-waiting">
                            <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                               Style="width:200px; height:4px;" />
                            <p>Generating questions…</p>
                        </div>
                    }
                    else
                    {
                        <div class="mp-topic-section">
                            <label class="mp-topic-label">Select Topic</label>
                            <RadzenDropDown @bind-Value="selectedTopic" Data="@topics"
                                            Style="width:100%; border-radius:var(--radius-input);"
                                            Placeholder="Pick a topic..." />
                        </div>
                        <RadzenButton Text="Start Game" Icon="play_arrow" ButtonStyle="ButtonStyle.Success"
                                      Disabled="@string.IsNullOrWhiteSpace(selectedTopic)"
                                      Style="width:100%; border-radius:var(--radius-input); padding:1rem; font-size:1.1rem; font-weight:700; margin-top:0.75rem;"
                                      Click="StartGame" />
                    }
                }
                else
                {
                    <div class="mp-waiting">
                        <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                           Style="width:200px; height:4px;" />
                        <p>@(currentState.Player2Name == "Waiting..." ? "Waiting for Player 2 to join…" : "Waiting for host to start…")</p>
                    </div>
                }
            }
            else
            {
                <div class="mp-waiting">
                    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                       Style="width:200px; height:4px;" />
                    <p>Starting game…</p>
                </div>
            }
        </div>
    }
</div>

<style>
