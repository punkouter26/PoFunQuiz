    @@media (prefers-color-scheme: dark) {
        .mp-score { color: var(--text-primary); }
        .mp-form-card { background: rgba(30,41,59,0.92) !important; }
    }
</style>

@code {
    private string playerName = string.Empty;
    private string activeTab = "create";
    private List<OpenGameInfo> openGames = [];
    private bool isLoadingGames = false;
    private GameStateDto? currentState;
    private bool isHost = false;
    private bool isStartingGame = false;
    private string? errorMessage;
    private string selectedTopic = string.Empty;

    private static readonly List<string> topics =
    [
        "General Knowledge", "Science", "History", "Sports",
        "Geography", "Technology", "Entertainment"
    ];

    protected override async Task OnInitializedAsync()
    {
        await GameService.InitializeAsync();
        GameService.OnGameUpdated += UpdateState;
        GameService.OnPlayerJoined += (_) => InvokeAsync(StateHasChanged);
        GameService.OnGameStarted += HandleGameStarted;
        GameService.OnScoreUpdated += UpdateState;
    }

    private void UpdateState(GameStateDto state)
    {
        InvokeAsync(() =>
        {
            currentState = state;
            StateHasChanged();
        });
    }

    /// <summary>
    /// Fires on both client devices when the host triggers StartGame.
    /// Builds a local GameSession from the DTO, stamps remote context onto GameState, and navigates.
    /// </summary>
    private void HandleGameStarted(GameStateDto state)
    {
        InvokeAsync(() =>
        {
            if (state.Questions is not { Count: > 0 })
            {
                // Questions not ready yet (shouldn't happen, but guard gracefully)
                currentState = state;
                StateHasChanged();
                return;
            }

            var session = new GameSession
            {
                GameId = state.GameId,
                Player1 = new Player
                {
                    Name = state.Player1Name,
                    Initials = state.Player1Name[..Math.Min(3, state.Player1Name.Length)].ToUpper()
                },
                Player2 = new Player
                {
                    Name = state.Player2Name,
                    Initials = state.Player2Name[..Math.Min(3, state.Player2Name.Length)].ToUpper()
                },
                // Both players share the same question list; each progresses independently
                Player1Questions = state.Questions,
                Player2Questions = state.Questions,
                StartTime = state.StartTime ?? DateTime.UtcNow
            };

            GameState.SetGame(session);
            GameState.SetRemoteContext(isHost ? 1 : 2, state.GameId);
            Navigation.NavigateTo("/game-board");
        });
    }

    private async Task CreateGame()
    {
        errorMessage = null;
        var gameId = await GameService.CreateGameAsync(playerName);
        if (string.IsNullOrEmpty(gameId))
        {
            errorMessage = "Failed to create game. Please try again.";
            return;
        }
        isHost = true;
        currentState = new GameStateDto
        {
            GameId = gameId,
            Player1Name = playerName,
            Player2Name = "Waiting...",
            Player1Score = 0,
            Player2Score = 0
        };
    }

    private async Task JoinOpenGame(string gameId)
    {
        errorMessage = null;
        var result = await GameService.JoinGameAsync(gameId, playerName);
        if (result.Success)
        {
            isHost = false;
        }
        else
        {
            errorMessage = result.FailReason switch
            {
                "already_started" => "That game has already started.",
                "already_full"    => "That game already has two players.",
                _                 => "Game not found — it may have been cancelled."
            };
            await RefreshOpenGames();
        }
    }

    private async Task RefreshOpenGames()
    {
        isLoadingGames = true;
        StateHasChanged();
        openGames = await GameService.GetOpenGamesAsync();
        isLoadingGames = false;
        StateHasChanged();
    }


    private async Task StartGame()
    {
        if (currentState != null && !string.IsNullOrWhiteSpace(selectedTopic))
        {
            isStartingGame = true;
            await GameService.StartGameAsync(currentState.GameId, selectedTopic);
        }
    }

    private static string SafeInitials(string? name) =>
        string.IsNullOrWhiteSpace(name) ? "?" : name[..Math.Min(2, name.Length)].ToUpperInvariant();

    public void Dispose()
    {
        GameService.OnGameUpdated -= UpdateState;
        GameService.OnGameStarted -= HandleGameStarted;
        GameService.OnScoreUpdated -= UpdateState;
    }
}
