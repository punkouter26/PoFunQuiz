@page "/"
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>PoFunQuiz</PageTitle>

<SectionContent SectionName="HeaderContent">
    <div class="d-flex align-items-center">
        <span class="app-title">PoFunQuiz</span>
    </div>
</SectionContent>

<div class="landing-container">
    <div class="landing-hero">
        <div class="landing-logo">
            <span class="material-icons logo-icon">quiz</span>
        </div>
        <h1 class="landing-title">PoFunQuiz</h1>
        <p class="landing-subtitle">Choose how you want to play</p>
    </div>

    <div class="mode-grid">
        <div class="mode-card local-card" @onclick="@(() => NavigationManager.NavigateTo("/local"))">
            <div class="mode-icon-wrap local-icon">
                <span class="material-icons">people_alt</span>
            </div>
            <div class="mode-body">
                <h2 class="mode-title">Local Play</h2>
                <p class="mode-desc">Two players, one device. Enter initials and battle it out!</p>
            </div>
            <span class="material-icons mode-arrow">chevron_right</span>
        </div>

        <div class="mode-card remote-card" @onclick="@(() => NavigationManager.NavigateTo("/multiplayer"))">
            <div class="mode-icon-wrap remote-icon">
                <span class="material-icons">wifi</span>
            </div>
            <div class="mode-body">
                <h2 class="mode-title">Remote Play</h2>
                <p class="mode-desc">Play online with a friend on separate devices via a shared lobby.</p>
            </div>
            <span class="material-icons mode-arrow">chevron_right</span>
        </div>

        <div class="mode-card leaderboard-card" @onclick="@(() => NavigationManager.NavigateTo("/leaderboard"))">
            <div class="mode-icon-wrap lb-icon">
                <span class="material-icons">emoji_events</span>
            </div>
            <div class="mode-body">
                <h2 class="mode-title">Leaderboard</h2>
                <p class="mode-desc">See the all-time top scores from players around the world.</p>
            </div>
            <span class="material-icons mode-arrow">chevron_right</span>
        </div>
    </div>
</div>

<style>
    .landing-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem 1rem;
        max-width: 520px;
        margin: 0 auto;
        padding-bottom: 100px;
        min-height: calc(100vh - 60px);
        justify-content: center;
    }

    .landing-hero {
        text-align: center;
        margin-bottom: 2.5rem;
    }

    .landing-logo {
        width: 72px;
        height: 72px;
        border-radius: 22px;
        background: linear-gradient(135deg, var(--rz-primary) 0%, var(--rz-secondary) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        box-shadow: 0 8px 24px rgba(99,102,241,0.4);
    }

    .logo-icon {
        font-size: 2.2rem !important;
        color: white;
    }

    .landing-title {
        font-size: var(--text-4xl);
        font-weight: 900;
        background: linear-gradient(135deg, var(--rz-primary) 0%, var(--rz-secondary) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0 0 0.4rem;
        font-family: var(--font-display, 'Poppins', sans-serif);
    }

    .landing-subtitle {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        font-weight: 500;
        margin: 0;
    }

    .mode-grid {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
        width: 100%;
    }

    .mode-card {
        background: var(--surface-color, #fff);
        border-radius: 20px;
        padding: 1.25rem 1rem 1.25rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: var(--shadow-md);
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        border: 1.5px solid transparent;
        position: relative;
        overflow: hidden;
    }

    .mode-card::before {
        content: '';
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.2s;
    }

    .local-card::before        { background: linear-gradient(135deg, rgba(99,102,241,0.06) 0%, rgba(129,140,248,0.06) 100%); }
    .remote-card::before       { background: linear-gradient(135deg, rgba(16,185,129,0.06) 0%, rgba(52,211,153,0.06) 100%); }
    .leaderboard-card::before  { background: linear-gradient(135deg, rgba(245,158,11,0.06) 0%, rgba(251,191,36,0.06) 100%); }

    .mode-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
    .mode-card:hover::before { opacity: 1; }
    .mode-card:active { transform: scale(0.98); box-shadow: var(--shadow-sm); }

    .mode-icon-wrap {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .mode-icon-wrap .material-icons { font-size: 1.7rem; color: white; }

    .local-icon  { background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%); }
    .remote-icon { background: linear-gradient(135deg, #10b981 0%, #34d399 100%); }
    .lb-icon     { background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%); }

    .mode-body { flex: 1; min-width: 0; }

    .mode-title {
        font-size: var(--text-base);
        font-weight: 800;
        margin: 0 0 3px;
        color: var(--text-primary);
        font-family: var(--font-display, 'Poppins', sans-serif);
    }

    .mode-desc {
        font-size: var(--text-xs);
        color: var(--text-secondary);
        margin: 0;
        line-height: 1.4;
    }

    .mode-arrow {
        color: var(--border-color);
        font-size: 1.4rem !important;
        flex-shrink: 0;
    }

    @@media (prefers-color-scheme: dark) {
        .mode-card { background: var(--surface-color); }
    }
</style>

