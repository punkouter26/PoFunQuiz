{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Azurite (Docker)",
      "type": "shell",
      "command": "docker compose up -d azurite",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Stop Azurite (Docker)",
      "type": "shell",
      "command": "docker compose stop azurite",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Start App (dev)",
      "type": "shell",
      "command": "dotnet run --project src/PoFunQuiz.Web/PoFunQuiz.Web.csproj",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": "Start Azurite (Docker)",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
